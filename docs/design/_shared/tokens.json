{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Banking design tokens v1 — Trust-Blue palette, Light mode only. Authored 2026-05-21 for balance-comparison sprint; consumed by all future banking features. W3C Design Tokens Community Group format (groups + $value + $type at leaf).",
  "$metadata": {
    "version": "1.0.0",
    "authored_by": "banking-designer",
    "authored_at": "2026-05-21",
    "scope": "all-features",
    "color_mode": "light",
    "dark_mode_planned": "v1.1 — token structure already supports mode-by-alias swap; do NOT inline hex in component specs",
    "consumers": ["banking-frontend-dev", "banking-tech-lead"],
    "license": "internal-only"
  },

  "color": {
    "$description": "Color palette. Primary scale (Trust-Blue 50→900), neutral scale, semantic (success/danger/warning/info), surface, text. All hex values have documented WCAG AA evidence — see tokens-rationale.md §Contrast Evidence.",

    "primary": {
      "50":  { "$value": "#EEF2FB", "$type": "color", "$description": "Lightest tint — banner subtle backgrounds" },
      "100": { "$value": "#D6DFF3", "$type": "color", "$description": "Hover surface for primary buttons" },
      "200": { "$value": "#AEC0E8", "$type": "color", "$description": "Disabled primary surface" },
      "300": { "$value": "#7E96D5", "$type": "color", "$description": "Decorative accents (non-text)" },
      "400": { "$value": "#5777C5", "$type": "color", "$description": "Reserved" },
      "500": { "$value": "#3B5BB8", "$type": "color", "$description": "Primary tint — hover state for primary surfaces" },
      "600": { "$value": "#2A4AA5", "$type": "color", "$description": "Reserved" },
      "700": { "$value": "#1E3A8A", "$type": "color", "$description": "PRIMARY brand — Trust-Blue (locked by stakeholder)" },
      "800": { "$value": "#162C6A", "$type": "color", "$description": "Active / pressed state for primary buttons" },
      "900": { "$value": "#0F1F4A", "$type": "color", "$description": "Reserved — high-emphasis dark accents" }
    },

    "neutral": {
      "0":   { "$value": "#FFFFFF", "$type": "color", "$description": "Pure white — surface" },
      "50":  { "$value": "#F8FAFC", "$type": "color", "$description": "Page background (subtle)" },
      "100": { "$value": "#F1F5F9", "$type": "color", "$description": "Muted surface — skeleton placeholder base" },
      "200": { "$value": "#E2E8F0", "$type": "color", "$description": "Hairline borders, divider lines" },
      "300": { "$value": "#CBD5E1", "$type": "color", "$description": "Disabled-state borders, skeleton highlights" },
      "400": { "$value": "#94A3B8", "$type": "color", "$description": "Tertiary text — placeholders, captions on dark" },
      "500": { "$value": "#64748B", "$type": "color", "$description": "Secondary text — passes AA on neutral-0" },
      "600": { "$value": "#475569", "$type": "color", "$description": "Body secondary text — passes AAA on neutral-0" },
      "700": { "$value": "#334155", "$type": "color", "$description": "Body text — strong" },
      "800": { "$value": "#1E293B", "$type": "color", "$description": "Headings" },
      "900": { "$value": "#0F172A", "$type": "color", "$description": "PRIMARY text — black-ish blue (locked by stakeholder)" }
    },

    "semantic": {
      "success": {
        "base":      { "$value": "#16A34A", "$type": "color", "$description": "Success base — locked by stakeholder" },
        "tint":      { "$value": "#DCFCE7", "$type": "color", "$description": "Success background (alert / badge fill)" },
        "on_base":   { "$value": "#FFFFFF", "$type": "color", "$description": "Text on success-base — AA verified" },
        "on_tint":   { "$value": "#14532D", "$type": "color", "$description": "Text on success-tint — AAA verified" }
      },
      "danger": {
        "base":      { "$value": "#DC2626", "$type": "color", "$description": "Danger / error base — locked by stakeholder" },
        "tint":      { "$value": "#FEE2E2", "$type": "color", "$description": "Danger background (toast / inline error fill)" },
        "on_base":   { "$value": "#FFFFFF", "$type": "color", "$description": "Text on danger-base — AA verified" },
        "on_tint":   { "$value": "#7F1D1D", "$type": "color", "$description": "Text on danger-tint — AAA verified" }
      },
      "warning": {
        "base":      { "$value": "#D97706", "$type": "color", "$description": "Warning base — locked by stakeholder; used for stale / degraded states" },
        "tint":      { "$value": "#FEF3C7", "$type": "color", "$description": "Warning background (staleness banner fill)" },
        "on_base":   { "$value": "#FFFFFF", "$type": "color", "$description": "Text on warning-base — AA verified" },
        "on_tint":   { "$value": "#78350F", "$type": "color", "$description": "Text on warning-tint — AAA verified" }
      },
      "info": {
        "base":      { "$value": "#0284C7", "$type": "color", "$description": "Informational base — for non-critical hints" },
        "tint":      { "$value": "#E0F2FE", "$type": "color", "$description": "Info background" },
        "on_base":   { "$value": "#FFFFFF", "$type": "color", "$description": "Text on info-base — AA verified" },
        "on_tint":   { "$value": "#075985", "$type": "color", "$description": "Text on info-tint — AAA verified" }
      }
    },

    "surface": {
      "page":      { "$value": "{color.neutral.50}",  "$type": "color", "$description": "Page-level background — alias to neutral-50" },
      "card":      { "$value": "{color.neutral.0}",   "$type": "color", "$description": "Card / row surface — alias to neutral-0 (white)" },
      "muted":     { "$value": "{color.neutral.100}", "$type": "color", "$description": "Muted surface — alias to neutral-100; used for skeleton base" },
      "elevated":  { "$value": "{color.neutral.0}",   "$type": "color", "$description": "Elevated surface (tooltip, popover) — alias to neutral-0" },
      "overlay":   { "$value": "rgba(15,23,42,0.40)", "$type": "color", "$description": "Modal scrim / dialog overlay" }
    },

    "text": {
      "primary":   { "$value": "{color.neutral.900}", "$type": "color", "$description": "Primary text — alias to neutral-900" },
      "secondary": { "$value": "{color.neutral.600}", "$type": "color", "$description": "Secondary text — alias to neutral-600; AA on surface.card" },
      "tertiary":  { "$value": "{color.neutral.500}", "$type": "color", "$description": "Tertiary / muted text — alias to neutral-500; AA on surface.card" },
      "disabled":  { "$value": "{color.neutral.400}", "$type": "color", "$description": "Disabled text — alias to neutral-400; intentionally below AA (non-actionable)" },
      "inverse":   { "$value": "{color.neutral.0}",   "$type": "color", "$description": "Inverse text on dark surfaces — alias to neutral-0" },
      "link":      { "$value": "{color.primary.700}", "$type": "color", "$description": "Link — alias to primary-700; AA on surface.card" },
      "link_hover":{ "$value": "{color.primary.800}", "$type": "color", "$description": "Link hover — alias to primary-800" }
    },

    "border": {
      "subtle":    { "$value": "{color.neutral.200}", "$type": "color", "$description": "Hairline divider" },
      "default":   { "$value": "{color.neutral.300}", "$type": "color", "$description": "Default border" },
      "strong":    { "$value": "{color.neutral.400}", "$type": "color", "$description": "Strong border (input focus halo base)" },
      "focus":     { "$value": "{color.primary.700}", "$type": "color", "$description": "Focus ring color — alias to primary-700" }
    }
  },

  "font_family": {
    "$description": "Thai-aware stacks. Inter is the primary; Sarabun is the Thai-optimized fallback; system stacks ensure no-network resilience.",
    "sans":      { "$value": "'Inter', 'Sarabun', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif", "$type": "fontFamily" },
    "tabular":   { "$value": "'Inter', 'Sarabun', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif", "$type": "fontFamily", "$description": "Same stack as sans; tabular numerals are activated via font-feature-settings (see typography.amount)" }
  },

  "font_weight": {
    "regular":  { "$value": 400, "$type": "fontWeight" },
    "medium":   { "$value": 500, "$type": "fontWeight" },
    "semibold": { "$value": 600, "$type": "fontWeight" },
    "bold":     { "$value": 700, "$type": "fontWeight" }
  },

  "font_size": {
    "xs":  { "$value": "12px", "$type": "dimension" },
    "sm":  { "$value": "14px", "$type": "dimension" },
    "md":  { "$value": "16px", "$type": "dimension" },
    "lg":  { "$value": "18px", "$type": "dimension" },
    "xl":  { "$value": "20px", "$type": "dimension" },
    "2xl": { "$value": "24px", "$type": "dimension" },
    "3xl": { "$value": "30px", "$type": "dimension" }
  },

  "line_height": {
    "tight":   { "$value": "1.2",  "$type": "number" },
    "snug":    { "$value": "1.4",  "$type": "number" },
    "normal":  { "$value": "1.5",  "$type": "number" },
    "relaxed": { "$value": "1.6",  "$type": "number" }
  },

  "typography": {
    "$description": "Composite typography tokens. Each composite references font_family + font_weight + font_size + line_height. The `amount` token is banking-special: activates tabular-nums for digit-column alignment.",

    "heading_1": {
      "$type": "typography",
      "$value": {
        "fontFamily":  "{font_family.sans}",
        "fontWeight":  "{font_weight.bold}",
        "fontSize":    "{font_size.2xl}",
        "lineHeight":  "{line_height.tight}"
      },
      "$description": "Page title (PageHeader); 24/29 Bold"
    },
    "heading_2": {
      "$type": "typography",
      "$value": {
        "fontFamily":  "{font_family.sans}",
        "fontWeight":  "{font_weight.semibold}",
        "fontSize":    "{font_size.xl}",
        "lineHeight":  "{line_height.snug}"
      },
      "$description": "Section heading; 20/28 Semibold"
    },
    "heading_3": {
      "$type": "typography",
      "$value": {
        "fontFamily":  "{font_family.sans}",
        "fontWeight":  "{font_weight.semibold}",
        "fontSize":    "{font_size.lg}",
        "lineHeight":  "{line_height.snug}"
      },
      "$description": "Sub-heading; 18/25 Semibold"
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily":  "{font_family.sans}",
        "fontWeight":  "{font_weight.regular}",
        "fontSize":    "{font_size.md}",
        "lineHeight":  "{line_height.normal}"
      },
      "$description": "Body text; 16/24 Regular — per stakeholder decision"
    },
    "body_strong": {
      "$type": "typography",
      "$value": {
        "fontFamily":  "{font_family.sans}",
        "fontWeight":  "{font_weight.semibold}",
        "fontSize":    "{font_size.md}",
        "lineHeight":  "{line_height.normal}"
      },
      "$description": "Body text strong (account type label); 16/24 Semibold"
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily":  "{font_family.sans}",
        "fontWeight":  "{font_weight.regular}",
        "fontSize":    "{font_size.xs}",
        "lineHeight":  "{line_height.snug}"
      },
      "$description": "Caption / last-updated label; 12/17 Regular"
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily":  "{font_family.sans}",
        "fontWeight":  "{font_weight.medium}",
        "fontSize":    "{font_size.sm}",
        "lineHeight":  "{line_height.snug}"
      },
      "$description": "UI labels (badges, chips); 14/20 Medium"
    },
    "amount": {
      "$type": "typography",
      "$value": {
        "fontFamily":     "{font_family.tabular}",
        "fontWeight":     "{font_weight.bold}",
        "fontSize":       "{font_size.xl}",
        "lineHeight":     "{line_height.snug}",
        "fontFeatureSettings": "'tnum' 1, 'lnum' 1"
      },
      "$description": "Banking amount display; 20/28 Bold with tabular numerals — banking convention for aligned digit columns. FE-dev MUST apply `font-variant-numeric: tabular-nums` OR `font-feature-settings: 'tnum' 1` on the element."
    },
    "amount_small": {
      "$type": "typography",
      "$value": {
        "fontFamily":     "{font_family.tabular}",
        "fontWeight":     "{font_weight.semibold}",
        "fontSize":       "{font_size.md}",
        "lineHeight":     "{line_height.snug}",
        "fontFeatureSettings": "'tnum' 1, 'lnum' 1"
      },
      "$description": "Smaller amount (single-row contexts); 16/22 Semibold tabular"
    }
  },

  "spacing": {
    "$description": "8-pixel base scale per stakeholder decision. Use these tokens for padding, margin, gap.",
    "0":   { "$value": "0px",  "$type": "dimension" },
    "1":   { "$value": "4px",  "$type": "dimension" },
    "2":   { "$value": "8px",  "$type": "dimension" },
    "3":   { "$value": "12px", "$type": "dimension" },
    "4":   { "$value": "16px", "$type": "dimension" },
    "5":   { "$value": "24px", "$type": "dimension" },
    "6":   { "$value": "32px", "$type": "dimension" },
    "7":   { "$value": "48px", "$type": "dimension" },
    "8":   { "$value": "64px", "$type": "dimension" }
  },

  "border_radius": {
    "$description": "Conservative radii — banking should feel structured, not playful.",
    "none":   { "$value": "0px",   "$type": "dimension" },
    "sm":     { "$value": "4px",   "$type": "dimension" },
    "md":     { "$value": "8px",   "$type": "dimension" },
    "lg":     { "$value": "12px",  "$type": "dimension" },
    "xl":     { "$value": "16px",  "$type": "dimension" },
    "pill":   { "$value": "999px", "$type": "dimension", "$description": "Full pill — used for badges only" },
    "button": { "$value": "{border_radius.md}",  "$type": "dimension", "$description": "Alias for button radius" },
    "card":   { "$value": "{border_radius.lg}",  "$type": "dimension", "$description": "Alias for card / row radius" },
    "input":  { "$value": "{border_radius.md}",  "$type": "dimension", "$description": "Alias for input radius" },
    "badge":  { "$value": "{border_radius.pill}","$type": "dimension", "$description": "Alias for badge radius" }
  },

  "border_width": {
    "0":     { "$value": "0px", "$type": "dimension" },
    "hairline": { "$value": "1px", "$type": "dimension" },
    "thick": { "$value": "2px", "$type": "dimension" },
    "focus": { "$value": "3px", "$type": "dimension", "$description": "Focus-ring outline width" }
  },

  "breakpoint": {
    "$description": "v1 ships mobile only (375px). Tablet/desktop tokens reserved but flagged DEFERRED to v1.1.",
    "mobile_sm": { "$value": "320px", "$type": "dimension", "$description": "Forward-compat reflow guard (per accessibility-notes.md §2)" },
    "mobile":    { "$value": "375px", "$type": "dimension", "$description": "v1 target — iPhone SE / typical Thai mobile" },
    "tablet":    { "$value": "768px", "$type": "dimension", "$description": "DEFERRED to v1.1 — token defined for forward-compat" },
    "desktop":   { "$value": "1280px", "$type": "dimension", "$description": "DEFERRED to v1.1 — token defined for forward-compat" }
  },

  "elevation": {
    "$description": "Subtle shadows — banking-conservative. No flashy depth. 3 levels only.",
    "0": { "$value": "none", "$type": "shadow", "$description": "Flat — no shadow" },
    "1": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "2px",  "spread": "0px", "color": "rgba(15,23,42,0.06)" },
      "$description": "Subtle — hairline lift on cards/rows"
    },
    "2": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "2px", "blur": "8px",  "spread": "0px", "color": "rgba(15,23,42,0.08)" },
      "$description": "Mild — sticky banners, popovers"
    },
    "3": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px", "color": "rgba(15,23,42,0.12)" },
      "$description": "Moderate — dialogs, modals only"
    }
  },

  "motion": {
    "$description": "Respect prefers-reduced-motion. When media query is set, FE-dev MUST swap duration to 0ms and skip non-essential animation.",
    "duration": {
      "instant": { "$value": "0ms",   "$type": "duration", "$description": "Used when prefers-reduced-motion: reduce" },
      "fast":    { "$value": "120ms", "$type": "duration", "$description": "Hover transitions, focus ring" },
      "normal":  { "$value": "200ms", "$type": "duration", "$description": "Badge fade-in, banner slide" },
      "slow":    { "$value": "320ms", "$type": "duration", "$description": "Modal / sheet entrance (not used in v1 dashboard)" }
    },
    "easing": {
      "standard":   { "$value": "cubic-bezier(0.2, 0, 0, 1)",     "$type": "cubicBezier", "$description": "Default ease — entering/exiting screen" },
      "decelerate": { "$value": "cubic-bezier(0, 0, 0, 1)",       "$type": "cubicBezier", "$description": "Element appearing" },
      "accelerate": { "$value": "cubic-bezier(0.3, 0, 1, 1)",     "$type": "cubicBezier", "$description": "Element leaving" }
    }
  },

  "size": {
    "$description": "Component-size tokens. Used for tap targets and icon sizing.",
    "tap_min":  { "$value": "44px", "$type": "dimension", "$description": "WCAG 2.5.5 minimum tap target — 44 x 44 dp" },
    "row_min":  { "$value": "72px", "$type": "dimension", "$description": "AccountRow minimum height (≥ 44 dp + 28 dp metadata)" },
    "icon_sm":  { "$value": "16px", "$type": "dimension" },
    "icon_md":  { "$value": "20px", "$type": "dimension" },
    "icon_lg":  { "$value": "24px", "$type": "dimension" },
    "icon_xl":  { "$value": "32px", "$type": "dimension" }
  },

  "z_index": {
    "base":      { "$value": 0,    "$type": "number" },
    "sticky":    { "$value": 100,  "$type": "number" },
    "banner":    { "$value": 200,  "$type": "number" },
    "popover":   { "$value": 800,  "$type": "number" },
    "modal":     { "$value": 1000, "$type": "number" },
    "toast":     { "$value": 1100, "$type": "number" }
  }
}
