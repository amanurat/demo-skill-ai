# Local dev credentials — single source of truth
# Copy this file to .env and adjust values if needed
#   cp .env.example .env

# PostgreSQL
POSTGRES_DB=transfer_db
POSTGRES_USER=transfer_user
POSTGRES_PASSWORD=transfer_pass

# Host port mappings (change if these ports are taken on your machine)
DB_PORT_HOST=5433
APP_PORT_HOST=8081
MGMT_PORT_HOST=9090
